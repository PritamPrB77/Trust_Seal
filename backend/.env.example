# Backend (FastAPI)
# Optional override (recommended for local no-network dev):
# DATABASE_URL=sqlite:///./trustseal.db
# For Supabase IPv4 networks, use Supabase pooler URL in DATABASE_URL.
# DATABASE_URL=postgresql://postgres.<project_ref>:<url_encoded_password>@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?sslmode=require
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=trustseal
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer
SECRET_KEY=replace-with-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
WS_REQUIRE_AUTH=false
REALTIME_QUEUE_MAXSIZE=5000
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-haiku
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_TIMEOUT_SECONDS=30
OPENROUTER_MAX_TOKENS=512
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=TrustSeal IoT
RAG_USE_OPENROUTER_EMBEDDINGS=true
RAG_REQUIRE_PGVECTOR=true
RAG_TOP_K=10
RAG_EMBEDDING_DIM=256
RAG_MAX_SENSOR_LOG_DOCS=500
RAG_MAX_CUSTODY_DOCS=300
SOC_AGENT_MODEL=anthropic/claude-3.5-haiku
SOC_AGENT_TIMEOUT_SECONDS=45
SOC_AGENT_MAX_ITERATIONS=8
SOC_AGENT_TOP_K=8
SOC_AGENT_BASELINE_WINDOW=200
SOC_AGENT_STREAM_TOOL_OUTPUT_CHARS=500
SOC_AGENT_INCIDENT_SEARCH_LIMIT=5
DB_CONNECT_TIMEOUT_SECONDS=8
DB_POOL_TIMEOUT_SECONDS=15
DB_POOL_RECYCLE_SECONDS=1800
