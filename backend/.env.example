# Backend (FastAPI)
# Optional override (recommended for local no-network dev):
# DATABASE_URL=sqlite:///./trustseal.db
# For Supabase IPv4 networks, use Supabase pooler URL in DATABASE_URL.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional regex for ephemeral preview domains (example: Vercel preview URLs)
# BACKEND_CORS_ORIGIN_REGEX=^https://v0-trust-seal-git-.*-pritamprayasbehera-9760s-projects\\.vercel\\.app$
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=trustseal
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer
SECRET_KEY=replace-with-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
WS_REQUIRE_AUTH=false
REALTIME_QUEUE_MAXSIZE=5000
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-haiku
OPENROUTER_TIMEOUT_SECONDS=30
OPENROUTER_MAX_TOKENS=512
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=TrustSeal IoT
# Optional if you want direct OpenAI instead of OpenRouter-compatible routing
OPENAI_API_KEY=
OPENAI_BASE_URL=
RAG_COLLECTION_NAME=trustseal_ops
RAG_EMBEDDING_MODEL=openai/text-embedding-3-small
RAG_EMBEDDING_DIMENSION=1536
RAG_TOP_K=6
RAG_MIN_RELEVANCE=0.25
RAG_TEMPERATURE=0.2
RAG_MAX_SHIPMENTS=300
RAG_MAX_DEVICES=300
RAG_MAX_SENSOR_LOGS=500
RAG_MAX_CUSTODY_CHECKPOINTS=500
RAG_TOOL_MAX_STEPS=5
CHAT_MEMORY_MAX_TURNS=8
CHAT_MEMORY_TTL_MINUTES=240
TEMPERATURE_THRESHOLD_C=8
AGENTIC_VECTOR_COLLECTION=trustseal_agentic_docs
AGENTIC_TOP_K=5
AGENTIC_SIMILARITY_THRESHOLD=0.35
AGENTIC_MMR_FETCH_K=20
AGENTIC_MMR_LAMBDA=0.5
AGENTIC_LLM_MODEL=anthropic/claude-3.5-haiku
AGENTIC_EMBEDDING_MODEL=openai/text-embedding-3-small
AGENTIC_CHUNK_SIZE=800
AGENTIC_CHUNK_OVERLAP=120
AGENTIC_BATCH_SIZE=32
AGENTIC_MAX_RESPONSE_TOKENS=450
AGENTIC_TEMPERATURE=0.2
AGENTIC_MAX_TOOL_STEPS=4
AGENTIC_POOL_MIN_SIZE=2
AGENTIC_POOL_MAX_SIZE=10
AGENTIC_SHORT_MEMORY_WINDOW=6
AGENTIC_SHORT_MEMORY_TTL_MINUTES=240
AGENTIC_LONG_MEMORY_TOP_K=4
